{
  "name": "mors",
  "version": "0.1.0",
  "description": "Markdown-first encrypted local CLI messaging",
  "type": "module",
  "bin": {
    "mors": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "if test -x node_modules/.bin/tsc; then node_modules/.bin/tsc -p tsconfig.build.json; fi",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "relay:dev": "npx tsx src/relay/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^11.10.0"
  }
}
