MORS_RELAY_PORT=3100
MORS_RELAY_BASE_URL=http://localhost:3100

# GitHub OAuth Device Flow placeholders
GITHUB_DEVICE_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_DEVICE_SCOPE=read:user
GITHUB_DEVICE_ENDPOINT=https://github.com/login/device/code
GITHUB_TOKEN_ENDPOINT=https://github.com/login/oauth/access_token

# Relay auth/session placeholders
# MORS_RELAY_SIGNING_KEY is the shared HMAC signing key for native auth tokens.
# Both CLI login and relay must use the same key for token coordination.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MORS_RELAY_SIGNING_KEY=replace-with-signing-key
MORS_AUTH_TOKEN_ISSUER=github-device-flow
MORS_AUTH_AUDIENCE=mors-relay

# Fly deploy placeholders
FLY_APP_NAME=replace-with-fly-app-name
FLY_PRIMARY_REGION=iad
FLY_ORG=replace-with-fly-org
